# Application
APP_NAME=Manibandha
ENVIRONMENT=development
# Comma-separated origins allowed by CORS (frontend dev server + prod domain)
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://manibandha.prema.su

# Security — generate a long random value for production:  openssl rand -hex 32
SECRET_KEY=change-me-in-production-please
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Database
DATABASE_URL=postgresql+psycopg2://manibandha:manibandha@localhost:5432/manibandha

# Initial guru/admin account created by `python -m app.seed`
FIRST_GURU_EMAIL=guru@manibandha.local
FIRST_GURU_PASSWORD=change-me
FIRST_GURU_NAME=Maharaj
